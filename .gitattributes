###############################################################################
# Git LFS (large binary assets)
###############################################################################

[attr]lfs filter=lfs diff=lfs merge=lfs -text

# 3D Models
*.fbx      lfs
*.obj      lfs
*.blend    lfs
*.dae      lfs
*.3ds      lfs
*.max      lfs

# Textures / Images
*.png      lfs
*.jpg      lfs
*.jpeg     lfs
*.tga      lfs
*.psd      lfs
*.exr      lfs
*.hdr      lfs

# Audio
*.wav      lfs
*.mp3      lfs
*.ogg      lfs

# Video
*.mp4      lfs
*.mov      lfs

# Fonts
*.ttf      lfs
*.otf      lfs

# Archives / large files
*.zip      lfs
*.rar      lfs
*.7z       lfs

###############################################################################
# Unity text serialization (KEEP MERGEABLE)
###############################################################################

# Unity YAML-based assets (DO NOT PUT IN LFS)
*.unity                text
*.prefab               text
*.asset                text
*.mat                  text
*.anim                 text
*.controller           text
*.meta                 text

###############################################################################
# Code & shaders
###############################################################################

*.cs       text diff=csharp
*.shader   text
*.compute  text
*.hlsl     text

###############################################################################
# Optional: reduce GitHub diff noise (safe for solo dev)
###############################################################################

Assets/Plugins/**           linguist-generated
Packages/packages-lock.json linguist-generated

###############################################################################
# Special cases
###############################################################################

# Lighting data (large + auto-generated)
LightingData.asset lfs
